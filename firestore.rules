rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ────────────────────────────────────────────────────────
    // Each user can read and write only their own document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Leaderboard ──────────────────────────────────────────────────────────
    // Anyone signed in can read the leaderboard.
    // Each user can only write their own entry (score is updated server-side via transactions).
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Multiplayer rooms ────────────────────────────────────────────────────
    // Any signed-in user can create or participate in rooms.
    match /rooms/{roomId} {
      allow read, write: if request.auth != null;
    }
  }
}
